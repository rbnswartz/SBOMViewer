@page "/"
@using Microsoft.EntityFrameworkCore
@using SBOMViewer.Data
@inject ApplicationDbContext DbContext
@rendermode InteractiveServer

<PageTitle>Home</PageTitle>

<h1>Dashboard</h1>

<p class="text-muted">Welcome to SBOMViewer — track your software and their dependencies using SBOM files.</p>

@if (isLoading)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="row g-4 mb-4">
        <div class="col-sm-4">
            <div class="card bg-primary text-white h-100">
                <div class="card-body d-flex flex-column justify-content-between">
                    <div class="d-flex justify-content-between align-items-start">
                        <h5 class="card-title">Software</h5>
                        <span class="bi bi-box-seam fs-3" aria-hidden="true"></span>
                    </div>
                    <p class="card-text display-6 fw-bold">@softwareCount</p>
                    <a href="/software" class="btn btn-outline-light btn-sm mt-2">View All</a>
                </div>
            </div>
        </div>
        <div class="col-sm-4">
            <div class="card bg-success text-white h-100">
                <div class="card-body d-flex flex-column justify-content-between">
                    <div class="d-flex justify-content-between align-items-start">
                        <h5 class="card-title">Dependencies</h5>
                        <span class="bi bi-diagram-3 fs-3" aria-hidden="true"></span>
                    </div>
                    <p class="card-text display-6 fw-bold">@dependencyCount</p>
                    <a href="/dependencies" class="btn btn-outline-light btn-sm mt-2">View All</a>
                </div>
            </div>
        </div>
        <div class="col-sm-4">
            <div class="card bg-info text-white h-100">
                <div class="card-body d-flex flex-column justify-content-between">
                    <div class="d-flex justify-content-between align-items-start">
                        <h5 class="card-title">Relationships</h5>
                        <span class="bi bi-link-45deg fs-3" aria-hidden="true"></span>
                    </div>
                    <p class="card-text display-6 fw-bold">@relationshipCount</p>
                    <p class="card-text text-white-50 small">Software–dependency links</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card h-100">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span>Software</span>
                    <a href="/software/create" class="btn btn-sm btn-primary">
                        <span class="bi bi-plus-lg" aria-hidden="true"></span> Add New
                    </a>
                </div>
                <div class="card-body p-0">
                    @if (!recentSoftware.Any())
                    {
                    <p class="p-3 text-muted mb-0">No software tracked yet. <a href="/software/create">Add your first software</a> to get started.</p>
                    }
                    else
                    {
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Description</th>
                                    <th>Dependencies</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in recentSoftware)
                                {
                                    <tr>
                                        <td><a href="/software/@item.Id">@item.Name</a></td>
                                        <td class="text-truncate" style="max-width:200px">@item.Description</td>
                                        <td>@item.DependencyCount</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
                @if (softwareCount > recentSoftware.Count)
                {
                    <div class="card-footer text-center">
                        <a href="/software">View all @softwareCount software items</a>
                    </div>
                }
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card h-100">
                <div class="card-header">Quick Actions</div>
                <div class="list-group list-group-flush">
                    <a href="/software/create" class="list-group-item list-group-item-action">
                        <span class="bi bi-box-seam me-2" aria-hidden="true"></span> Add Software
                    </a>
                    <a href="/dependencies/create" class="list-group-item list-group-item-action">
                        <span class="bi bi-diagram-3 me-2" aria-hidden="true"></span> Add Dependency
                    </a>
                    <a href="/software" class="list-group-item list-group-item-action">
                        <span class="bi bi-list me-2" aria-hidden="true"></span> Browse Software
                    </a>
                    <a href="/dependencies" class="list-group-item list-group-item-action">
                        <span class="bi bi-list me-2" aria-hidden="true"></span> Browse Dependencies
                    </a>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool isLoading = true;
    private int softwareCount;
    private int dependencyCount;
    private int relationshipCount;
    private List<SoftwareSummary> recentSoftware = new();

    protected override async Task OnInitializedAsync()
    {
        softwareCount = await DbContext.Software.CountAsync();
        dependencyCount = await DbContext.Dependencies.CountAsync();
        relationshipCount = await DbContext.SoftwareDependencies.CountAsync();

        recentSoftware = await DbContext.Software
            .OrderBy(s => s.Name)
            .Take(5)
            .Select(s => new SoftwareSummary
            {
                Id = s.Id,
                Name = s.Name,
                Description = s.Description,
                DependencyCount = s.Dependencies.Count
            })
            .ToListAsync();

        isLoading = false;
    }

    private class SoftwareSummary
    {
        public int Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public int DependencyCount { get; set; }
    }
}
