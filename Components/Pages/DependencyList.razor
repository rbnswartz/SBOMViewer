@page "/dependencies"
@using Microsoft.EntityFrameworkCore
@using SBOMViewer.Data
@inject ApplicationDbContext DbContext
@inject NavigationManager Navigation
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Dependencies</PageTitle>

<h1>Dependencies</h1>

<p>
    <button class="btn btn-primary" @onclick="CreateNew">Create New</button>
</p>

<div class="row mb-3 g-2">
    <div class="col-sm-5">
        <input type="text" class="form-control" placeholder="Search by name…" @bind="searchName" @bind:event="oninput" />
    </div>
    <div class="col-sm-4">
        <select class="form-select" @bind="selectedEcosystem">
            <option value="">All Ecosystems</option>
            @foreach (var eco in ecosystems)
            {
                <option value="@eco">@eco</option>
            }
        </select>
    </div>
</div>

@if (dependencies == null)
{
    <p><em>Loading...</em></p>
}
else
{
    var filtered = FilteredDependencies;
    @if (!filtered.Any())
    {
        <p><em>No dependencies match the current filters.</em></p>
    }
    else
    {
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Type</th>
                    <th>Ecosystem</th>
                    <th>Description</th>
                    <th>Registry</th>
                    <th>Usage Count</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in filtered)
                {
                    <tr>
                        <td>
                            <a href="/dependencies/@item.Id">@item.Name</a>
                        </td>
                        <td>@item.Type</td>
                        <td>@item.Ecosystem</td>
                        <td>@item.Description</td>
                        <td>
                            @{
                                var registryUrl = PurlHelper.GetRegistryUrl(item.PackageUrl);
                            }
                            @if (registryUrl != null)
                            {
                                <a href="@registryUrl" target="_blank" rel="noopener noreferrer">@PurlHelper.GetRegistryLabel(item.PackageUrl)</a>
                            }
                            else if (!string.IsNullOrEmpty(item.PackageUrl))
                            {
                                <code class="text-break">@item.PackageUrl</code>
                            }
                        </td>
                        <td>@item.UsageCount</td>
                        <td>
                            <button class="btn btn-sm btn-primary" @onclick="() => Edit(item.Id)">Edit</button>
                            <button class="btn btn-sm btn-danger" @onclick="() => Delete(item.Id)">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

@code {
    private List<DependencyViewModel>? dependencies;
    private List<string> ecosystems = new();
    private string searchName = string.Empty;
    private string selectedEcosystem = string.Empty;

    private IEnumerable<DependencyViewModel> FilteredDependencies =>
        (dependencies ?? Enumerable.Empty<DependencyViewModel>())
            .Where(d => string.IsNullOrEmpty(searchName) ||
                        d.Name.Contains(searchName, StringComparison.OrdinalIgnoreCase))
            .Where(d => string.IsNullOrEmpty(selectedEcosystem) ||
                        string.Equals(d.Ecosystem, selectedEcosystem, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        var deps = await DbContext.Dependencies
            .Include(d => d.SoftwareUsages)
            .OrderBy(d => d.Name)
            .ToListAsync();

        dependencies = deps.Select(d => new DependencyViewModel
        {
            Id = d.Id,
            Name = d.Name,
            Description = d.Description,
            Type = d.Type,
            Ecosystem = d.Ecosystem,
            PackageUrl = d.PackageUrl,
            UsageCount = d.SoftwareUsages.Count
        }).ToList();

        ecosystems = deps
            .Select(d => d.Ecosystem)
            .OfType<string>()
            .Distinct()
            .Order()
            .ToList();
    }

    private void CreateNew()
    {
        Navigation.NavigateTo("/dependencies/create");
    }

    private void Edit(int id)
    {
        Navigation.NavigateTo($"/dependencies/edit/{id}");
    }

    private async Task Delete(int id)
    {
        var item = await DbContext.Dependencies
            .Include(d => d.SoftwareUsages)
            .FirstOrDefaultAsync(d => d.Id == id);
            
        if (item != null)
        {
            if (item.SoftwareUsages.Any())
            {
                if (!await JS.InvokeAsync<bool>("confirm", $"'{item.Name}' is used by {item.SoftwareUsages.Count} software item(s). Deleting this dependency will remove it from all software. Are you sure?"))
                {
                    return;
                }
            }
            else
            {
                if (!await JS.InvokeAsync<bool>("confirm", $"Are you sure you want to delete '{item.Name}'?"))
                {
                    return;
                }
            }
            
            DbContext.Dependencies.Remove(item);
            await DbContext.SaveChangesAsync();
            await LoadData();
        }
    }

    private class DependencyViewModel
    {
        public int Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public string? Type { get; set; }
        public string? Ecosystem { get; set; }
        public string? PackageUrl { get; set; }
        public int UsageCount { get; set; }
    }
}
