@page "/dependencies/create"
@page "/dependencies/edit/{id:int}"
@using Microsoft.EntityFrameworkCore
@using SBOMViewer.Data
@using System.ComponentModel.DataAnnotations
@inject ApplicationDbContext DbContext
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>@(Id == null ? "Create Dependency" : "Edit Dependency")</PageTitle>

<h1>@(Id == null ? "Create Dependency" : "Edit Dependency")</h1>

<EditForm Model="@model" OnValidSubmit="@HandleSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label for="name" class="form-label">Name</label>
        <InputText id="name" class="form-control" @bind-Value="model.Name" />
        <ValidationMessage For="@(() => model.Name)" />
    </div>

    <div class="mb-3">
        <label for="type" class="form-label">Type</label>
        <InputText id="type" class="form-control" @bind-Value="model.Type" placeholder="e.g. library, framework, application" />
        <ValidationMessage For="@(() => model.Type)" />
    </div>

    <div class="mb-3">
        <label for="ecosystem" class="form-label">Ecosystem</label>
        <InputText id="ecosystem" class="form-control" @bind-Value="model.Ecosystem" placeholder="e.g. npm, maven, pypi, nuget" />
        <ValidationMessage For="@(() => model.Ecosystem)" />
    </div>

    <div class="mb-3">
        <label for="description" class="form-label">Description</label>
        <InputTextArea id="description" class="form-control" @bind-Value="model.Description" rows="3" />
        <ValidationMessage For="@(() => model.Description)" />
    </div>

    <div class="mb-3">
        <label for="packageUrl" class="form-label">Package URL (purl)</label>
        <InputText id="packageUrl" class="form-control" @bind-Value="model.PackageUrl" placeholder="e.g. pkg:npm/lodash@4.17.21" />
        <ValidationMessage For="@(() => model.PackageUrl)" />
    </div>

    <div>
        <button type="submit" class="btn btn-primary">Save</button>
        <button type="button" class="btn btn-secondary" @onclick="Cancel">Cancel</button>
    </div>
</EditForm>

@code {
    [Parameter]
    public int? Id { get; set; }

    private DependencyModel model = new();

    protected override async Task OnInitializedAsync()
    {
        if (Id.HasValue)
        {
            var dependency = await DbContext.Dependencies.FindAsync(Id.Value);
            if (dependency != null)
            {
                model.Name = dependency.Name;
                model.Description = dependency.Description;
                model.Type = dependency.Type;
                model.Ecosystem = dependency.Ecosystem;
                model.PackageUrl = dependency.PackageUrl;
            }
        }
    }

    private async Task HandleSubmit()
    {
        if (Id.HasValue)
        {
            var dependency = await DbContext.Dependencies.FindAsync(Id.Value);
            if (dependency != null)
            {
                dependency.Name = model.Name;
                dependency.Description = model.Description;
                dependency.Type = model.Type;
                dependency.Ecosystem = model.Ecosystem;
                dependency.PackageUrl = model.PackageUrl;
            }
        }
        else
        {
            var dependency = new Dependency
            {
                Name = model.Name,
                Description = model.Description,
                Type = model.Type,
                Ecosystem = model.Ecosystem,
                PackageUrl = model.PackageUrl
            };
            DbContext.Dependencies.Add(dependency);
        }

        await DbContext.SaveChangesAsync();
        Navigation.NavigateTo("/dependencies");
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/dependencies");
    }

    public class DependencyModel
    {
        [Required]
        [StringLength(200)]
        public string Name { get; set; } = string.Empty;

        [StringLength(100)]
        public string? Type { get; set; }

        [StringLength(100)]
        public string? Ecosystem { get; set; }

        [StringLength(500)]
        public string? Description { get; set; }

        [StringLength(1000)]
        public string? PackageUrl { get; set; }
    }
}
